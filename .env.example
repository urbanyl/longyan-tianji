# Discord identity
DISCORD_TOKEN=your_discord_token
DISCORD_CLIENT_ID=your_discord_client_id
COMMAND_PREFIX=!
PROJECT_NAME=Longyan
BOT_NAME=Tianji

# Discord access control
SECURITY_REQUIRE_ALLOWLIST=true
ALLOW_PUBLIC_COMMANDS=true
ALLOW_DIRECT_MESSAGES=false
ALLOWED_GUILD_IDS=
ALLOWED_CHANNEL_IDS=
ALLOWED_USER_IDS=
ALLOWED_ROLE_IDS=
ADMIN_USER_IDS=
ADMIN_ROLE_IDS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_COMMANDS=12
BYPASS_RATE_LIMIT_FOR_ADMINS=true

# Task queue and execution budgets
MAX_CONCURRENT_TASKS=4
MAX_QUEUE_SIZE=50
MAX_QUEUED_TASKS_PER_USER=3
MAX_COMMAND_CHARS=6000
MAX_PLAN_STEPS=6
TASK_TIMEOUT_MS=120000
REPLY_WAIT_MS=60000
CODE_TIMEOUT_MS=30000
CODE_MAX_CHARS=12000
CODE_MAX_OUTPUT_CHARS=12000

# Memory
MEMORY_DB_PATH=./longyan-memory.db
ALLOW_MEMORY_DB_OUTSIDE_ROOT=false
MEMORY_SCOPE=user
MEMORY_MAX_VALUE_CHARS=200000
MEMORY_LIST_LIMIT=20

# Personal assistant profile
ASSISTANT_DEFAULT_BOT_NAME=
ASSISTANT_DEFAULT_USER_NAME=
ASSISTANT_DEFAULT_SPEAKING_STYLE=warm, concise, professional
ASSISTANT_DEFAULT_PERSONALITY=Personal automation assistant with a calm enterprise tone.
ASSISTANT_MAX_PROFILE_NOTES_CHARS=200000
ASSISTANT_MAX_PREFERENCE_VALUE_CHARS=50000

# Docker sandbox
# Leave empty for the platform default:
# Linux/macOS Docker socket: /var/run/docker.sock
# Windows Docker Desktop pipe: //./pipe/docker_engine
DOCKER_SOCKET=
DOCKER_NETWORK=none
AUTO_PULL_IMAGES=false
PYTHON_IMAGE=python:3.11-slim
NODE_IMAGE=node:20-slim
DOCKER_RUN_USER=1000:1000
DOCKER_MEMORY_MB=512
DOCKER_CPU_QUOTA=50000
DOCKER_PIDS_LIMIT=128
DOCKER_TMPFS_SIZE_MB=64
DOCKER_READONLY_ROOTFS=true
DOCKER_CAP_DROP_ALL=true
DOCKER_NO_NEW_PRIVILEGES=true

# Browser automation
BROWSER_HEADLESS=true
BROWSER_DISABLE_SANDBOX=false
BROWSER_ALLOW_EVAL=false
BROWSER_ALLOW_PRIVATE_NETWORKS=false
BROWSER_ALLOWED_HOSTS=
BROWSER_BLOCKED_HOSTS=
BROWSER_TIMEOUT_MS=45000
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080
BROWSER_MAX_TEXT_CHARS=4000
BROWSER_MAX_LINKS=20
BROWSER_MAX_SCREENSHOT_BYTES=8388608
BROWSER_FULL_PAGE_SCREENSHOTS=false

# Files and replies
TEMP_DIR=./temp
ALLOW_TEMP_DIR_OUTSIDE_ROOT=false
TEMP_FILE_TTL_MS=86400000
# summary, files, json, or silent
DEFAULT_REPLY_MODE=summary
MAX_REPLY_CHARS=1800
MAX_ATTACHMENT_FILES=8
MAX_ATTACHMENT_BYTES=8388608
MAX_FILE_INPUT_CHARS=100000

# External research
FREE_SEARCH_ENABLED=true
SERPAPI_ENABLED=false
RESEARCH_TIMEOUT_MS=12000
RESEARCH_MAX_RESULTS=5
SERPAPI_KEY=

# Local dashboard / GUI
LOCAL_DASHBOARD_ENABLED=false
LOCAL_DASHBOARD_HOST=127.0.0.1
LOCAL_DASHBOARD_PORT=3010
LOCAL_DASHBOARD_OPEN=false
LOCAL_DASHBOARD_TOKEN=
LOCAL_DASHBOARD_USER_ID=local-user
LOCAL_DASHBOARD_MAX_BODY_CHARS=1000000
