# Discord identity
DISCORD_TOKEN=your_discord_token
DISCORD_CLIENT_ID=your_discord_client_id
COMMAND_PREFIX=!
PROJECT_NAME=Longyan
BOT_NAME=Tianji

# Discord access control
SECURITY_REQUIRE_ALLOWLIST=true
ALLOW_PUBLIC_COMMANDS=true
ALLOW_DIRECT_MESSAGES=false
ALLOWED_GUILD_IDS=
ALLOWED_CHANNEL_IDS=
ALLOWED_USER_IDS=
ALLOWED_ROLE_IDS=
ADMIN_USER_IDS=
ADMIN_ROLE_IDS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_COMMANDS=12
BYPASS_RATE_LIMIT_FOR_ADMINS=true

# Task queue and execution budgets
MAX_CONCURRENT_TASKS=4
MAX_QUEUE_SIZE=50
MAX_QUEUED_TASKS_PER_USER=3
MAX_COMMAND_CHARS=6000
MAX_PLAN_STEPS=6
TASK_TIMEOUT_MS=120000
REPLY_WAIT_MS=60000
CODE_TIMEOUT_MS=30000
CODE_MAX_CHARS=12000
CODE_MAX_OUTPUT_CHARS=12000

# Memory
MEMORY_DB_PATH=./longyan-memory.db
ALLOW_MEMORY_DB_OUTSIDE_ROOT=false
MEMORY_SCOPE=user
MEMORY_MAX_VALUE_CHARS=8000
MEMORY_LIST_LIMIT=20

# Docker sandbox
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=none
AUTO_PULL_IMAGES=false
PYTHON_IMAGE=python:3.11-slim
NODE_IMAGE=node:20-slim
DOCKER_RUN_USER=1000:1000
DOCKER_MEMORY_MB=512
DOCKER_CPU_QUOTA=50000
DOCKER_PIDS_LIMIT=128
DOCKER_TMPFS_SIZE_MB=64
DOCKER_READONLY_ROOTFS=true
DOCKER_CAP_DROP_ALL=true
DOCKER_NO_NEW_PRIVILEGES=true

# Browser automation
BROWSER_HEADLESS=true
BROWSER_DISABLE_SANDBOX=false
BROWSER_ALLOW_EVAL=false
BROWSER_ALLOW_PRIVATE_NETWORKS=false
BROWSER_ALLOWED_HOSTS=
BROWSER_BLOCKED_HOSTS=
BROWSER_TIMEOUT_MS=45000
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080
BROWSER_MAX_TEXT_CHARS=4000
BROWSER_MAX_LINKS=20
BROWSER_MAX_SCREENSHOT_BYTES=8388608
BROWSER_FULL_PAGE_SCREENSHOTS=false

# Files and replies
TEMP_DIR=./temp
ALLOW_TEMP_DIR_OUTSIDE_ROOT=false
TEMP_FILE_TTL_MS=86400000
MAX_REPLY_CHARS=1800
MAX_ATTACHMENT_FILES=8
MAX_ATTACHMENT_BYTES=8388608
MAX_FILE_INPUT_CHARS=100000

# External research
SERPAPI_KEY=
